{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/uploads/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/((?!assets|pictures|icons|videos|api|uploads|favicon.ico|sitemap.xml|robots.txt).*)",
      "destination": "/index.html"
    }
  ]
}
